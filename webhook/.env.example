# ─── Telegram Bot Configuration ──────────────────────────────
# Create a bot via @BotFather on Telegram and paste the token here.
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat ID of the group/channel to receive alerts.
# Tip: add @userinfobot to your group to get the chat ID.
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Webhook Security ───────────────────────────────────────
# Shared secret between Laravel and this webhook service.
# Leave empty to disable secret validation (not recommended in production).
WEBHOOK_SECRET=your_secret_key_here

# ─── Monitoring Scheduler ───────────────────────────────────
# Enable/disable the built-in async monitoring scheduler.
MONITOR_ENABLED=true

# JSON array of targets to monitor.
# Each target: {"name": "...", "url": "...", "interval": <seconds>}
MONITOR_TARGETS=[{"name":"Laravel-App","url":"http://localhost:8000/health","interval":60},{"name":"Webhook-Self","url":"http://localhost:9000/health","interval":120}]

# ─── Alert Settings ─────────────────────────────────────────
# Minimum seconds between duplicate alerts for the same service+status.
ALERT_COOLDOWN_SECONDS=300

# Send "RECOVERED" alerts when a service comes back UP.
SEND_RECOVERY_ALERTS=true

# ─── Server ─────────────────────────────────────────────────
HOST=0.0.0.0
PORT=9000
LOG_LEVEL=INFO
